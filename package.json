{
  "name": "fridge2recipe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @fridge2recipe/web dev",
    "dev:api": "pnpm --filter @fridge2recipe/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "agent:up": "bash scripts/agent/up.sh",
    "agent:down": "bash scripts/agent/down.sh",
    "agent:reset": "bash scripts/agent/reset.sh",
    "agent:seed": "bash scripts/agent/seed.sh",
    "agent:logs": "bash scripts/agent/logs.sh",
    "agent:screenshot": "bash scripts/agent/screenshot-home.sh",
    "agent:run": "bash scripts/agent/run.sh"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "playwright": "^1.51.1",
    "prettier": "^3.6.2"
  }
}
