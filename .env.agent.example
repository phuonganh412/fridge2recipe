# Agent harness environment — copy to .env.agent.local (gitignored).
# After `supabase start`, run `supabase status` for local keys.

AGENT_MODE=1
AGENT_TEST_USER_EMAIL=test@agent.local
AGENT_TEST_USER_PASSWORD=change-me-agent-test
AGENT_MAX_ITERATIONS=10
AGENT_WALL_CLOCK_MINUTES=120
AGENT_LOG_SINCE=15m

# Local Supabase (from `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Web + API (browser/Playwright on host use localhost)
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
PORT=3001

# Placeholder until AI features are tested in agent runs
AI_GATEWAY_API_KEY=placeholder
